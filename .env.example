# ===== AUTH0 =====
AUTH0_DOMAIN=your-tenant.auth0.com
AUTH0_CLIENT_ID=your-client-id
AUTH0_CLIENT_SECRET=your-client-secret
AUTH0_AUDIENCE=https://api.aegiscloud.dev
AUTH0_M2M_CLIENT_ID=your-m2m-client-id
AUTH0_M2M_CLIENT_SECRET=your-m2m-client-secret
AUTH0_USER_ID=auth0|your-user-id
# Token Vault Custom API Client (resource server type for RFC 8693 exchange)
AUTH0_TOKEN_VAULT_CLIENT_ID=your-token-vault-client-id
AUTH0_TOKEN_VAULT_CLIENT_SECRET=your-token-vault-client-secret

# ===== GOOGLE GEMINI =====
GOOGLE_API_KEY=your-gemini-api-key

# ===== APP =====
APP_SECRET_KEY=generate-a-random-secret
DATABASE_URL=sqlite:///./aegiscloud.db
FRONTEND_URL=http://localhost:3000
BACKEND_URL=http://localhost:8000

# ===== FEATURE FLAGS =====
AWS_MOCK_MODE=true
