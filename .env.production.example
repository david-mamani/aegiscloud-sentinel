# === Auth0 Backend (M2M / Non-Interactive Client) ===
AUTH0_DOMAIN=your-tenant.us.auth0.com
AUTH0_CLIENT_ID=<backend-m2m-client-id>
AUTH0_CLIENT_SECRET=<backend-m2m-client-secret>
AUTH0_AUDIENCE=https://api.aegiscloud.dev
AUTH0_M2M_CLIENT_ID=<same-as-above>
AUTH0_M2M_CLIENT_SECRET=<same-as-above>
AUTH0_USER_ID=auth0|<your-user-id>

# === Auth0 Frontend (Regular Web App Client) ===
AUTH0_CLIENT_ID_FRONTEND=<frontend-client-id>
AUTH0_CLIENT_SECRET_FRONTEND=<frontend-client-secret>
AUTH0_SECRET=<random-32-char-secret-for-sessions>

# === Google Gemini ===
GOOGLE_API_KEY=<your-gemini-api-key>

# === URLs (CHANGE THESE FOR YOUR DOMAIN) ===
FRONTEND_URL=https://aegis.yourdomain.com
APP_BASE_URL=https://aegis.yourdomain.com
NEXT_PUBLIC_API_URL=https://aegis-api.yourdomain.com
